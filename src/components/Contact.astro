---
import { en, tr } from "../data/portfolio";
import { t } from "../i18n";
import HudSection from "./HudSection.astro";
const locale = Astro.currentLocale;
const { profile } = locale === "tr" ? tr : en;
---

<HudSection id="contact" labelledby="contact-title" number="06" label={t(locale, "contact.chapter")} class="contact">
  <div class="choice-dialogue" data-reveal>
    <p class="chapter-label">{t(locale, "contact.chapter")}</p>
    <h2 id="contact-title">{t(locale, "contact.title")}</h2>
    <div class="choice-list">
      <a href={`mailto:${profile.email}`}>
        <span>A</span>
        <strong>{t(locale, "contact.offerQuest")}</strong>
      </a>
      <a href={profile.linkedin} target="_blank" rel="noreferrer">
        <span>B</span>
        <strong>{t(locale, "contact.inspectNetwork")}</strong>
      </a>
      <a href={profile.cv} download>
        <span>C</span>
        <strong>{t(locale, "contact.downloadArchives")}</strong>
      </a>
    </div>
  </div>
</HudSection>
