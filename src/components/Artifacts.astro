---
import { en, tr } from "../data/portfolio";
import { t } from "../i18n";
import HudSection from "./HudSection.astro";
const locale = Astro.currentLocale;
const { projects } = locale === "tr" ? tr : en;
---

<HudSection
  id="artifacts"
  labelledby="artifacts-title"
  number="05"
  label={t(locale, "artifacts.chapter")}
  class="artifacts"
>
  <div data-artifacts>
    <div class="artifacts__intro" data-reveal>
      <h2 id="artifacts-title">{t(locale, "artifacts.title")}</h2>
    </div>

    <div class="artifact-rail__wrap">
      <button class="artifact-arrow artifact-arrow--prev" aria-label="Previous" data-arrow="prev">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>

      <div class="artifact-rail" aria-label="Project gallery" data-reveal>
        {projects.map((project) => (
          <article class="artifact-card">
            <div class="artifact-card__cover">
              <span>{project.kind}</span>
              <strong>{project.title}</strong>
            </div>
            <div class="artifact-card__body">
              <p>{project.theme}</p>
              <p>{project.summary}</p>
              <div>
                {project.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>

      <button class="artifact-arrow artifact-arrow--next" aria-label="Next" data-arrow="next">
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>
</HudSection>

<script>
  const wrap = document.querySelector(".artifact-rail__wrap");
  const rail = wrap?.querySelector(".artifact-rail");
  if (wrap instanceof HTMLElement && rail instanceof HTMLElement) {
    const getScrollAmount = () => {
      const card = rail.querySelector(".artifact-card");
      if (!card) return 200;
      return card.getBoundingClientRect().width + 16;
    };

    wrap.querySelectorAll("[data-arrow]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const dir = (btn as HTMLElement).dataset.arrow;
        rail.scrollBy({ left: dir === "next" ? getScrollAmount() : -getScrollAmount(), behavior: "smooth" });
      });
    });

    rail.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowRight") rail.scrollBy({ left: getScrollAmount(), behavior: "smooth" });
      if (e.key === "ArrowLeft") rail.scrollBy({ left: -getScrollAmount(), behavior: "smooth" });
    });
  }
</script>
