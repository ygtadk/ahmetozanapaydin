---
import { en, tr } from "../data/portfolio";
import { t } from "../i18n";
import HudSection from "./HudSection.astro";
const locale = Astro.currentLocale;
const { profile } = locale === "tr" ? tr : en;
---

<HudSection
  id="awakening"
  labelledby="hero-title"
  number="01"
  label={t(locale, "chapter.awakening")}
  class="hero"
>
  <div class="hero-stage">
    <div class="hero__identity">
      <h1 id="hero-title">{profile.name}</h1>
      <p>{profile.title}</p>
    </div>
    <a class="hero__scroll-cue" href="#lore">{t(locale, "hero.beginInspection")}</a>
  </div>
</HudSection>
